{
  "name": "bringback",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "contract:compile": "hardhat compile",
    "contract:test": "hardhat test",
    "contract:deploy:testnet": "hardhat run scripts/deploy.cjs --network monadTestnet",
    "contract:deploy:mainnet": "hardhat run scripts/deploy.cjs --network monadMainnet",
    "test": "npm run contract:test && npm run typecheck"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "hardhat": "^2.22.18",
    "typescript": "~5.6.3",
    "vite": "^6.0.5"
  }
}
